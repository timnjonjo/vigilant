# Dev configuration. Copy to `.env` and adjust.

# Runs against the in-memory mock by default — no backend and NO Keycloak needed.
# Set to false to use the real backend + Keycloak login.
VITE_USE_MOCK=true

# Real backend (VITE_USE_MOCK=false): empty base URL uses the Vite dev proxy to :8080.
VITE_API_BASE_URL=

# Keycloak OIDC (used only when VITE_USE_MOCK=false).
VITE_OIDC_AUTHORITY=http://localhost:8081/realms/vigilant
VITE_OIDC_CLIENT_ID=vigilant-dashboard

# Fallback tenant for mock mode (real mode takes the tenant from the token).
VITE_TENANT_ID=loob-bank
